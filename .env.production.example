# ==============================
# AI법친 불법사금융 홍보 운영 설정
# ==============================
NEXT_PUBLIC_AIBEOPCHIN_PROMO_ANALYTICS_ENABLED=true

# GA4
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX

# Meta Pixel
NEXT_PUBLIC_META_PIXEL_ID=000000000000000

# 팝업 노출 정책
NEXT_PUBLIC_AIBEOPCHIN_PROMO_POPUP_ENABLED=true
NEXT_PUBLIC_AIBEOPCHIN_PROMO_POPUP_COOLDOWN_HOURS=24

# A/B 테스트
# A | B | auto
NEXT_PUBLIC_ILLEGAL_LENDING_PROMO_VARIANT=auto

# Jeonse Damage Promo
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_POPUP_ENABLED=true
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_POPUP_COOLDOWN_HOURS=24
NEXT_PUBLIC_JEONSE_DAMAGE_PROMO_VARIANT=auto

# Free Service Promo Popup Exposure Policy
# rotation | illegal_only | jeonse_only | disabled
NEXT_PUBLIC_AIBEOPCHIN_FREE_SERVICE_PROMO_MODE=rotation

# 팝업 순환 기준
# session | daily
NEXT_PUBLIC_AIBEOPCHIN_FREE_SERVICE_PROMO_ROTATION_SCOPE=daily

# ==============================
# AI법친 불법사금융 운영 인프라
# ==============================
ILLEGAL_LENDING_STORAGE_DRIVER=r2
ILLEGAL_LENDING_UPLOAD_ROOT=.private-uploads/illegal-lending
ILLEGAL_LENDING_S3_BUCKET=
ILLEGAL_LENDING_S3_REGION=auto
ILLEGAL_LENDING_S3_ENDPOINT=
ILLEGAL_LENDING_S3_ACCESS_KEY_ID=
ILLEGAL_LENDING_S3_SECRET_ACCESS_KEY=
ILLEGAL_LENDING_S3_FORCE_PATH_STYLE=true
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
ILLEGAL_LENDING_SUPABASE_BUCKET=illegal-lending-private
PDF_KOREAN_FONT_PATH=/private/fonts/NotoSansKR-Regular.ttf
ILLEGAL_LENDING_AUTO_ASSIGN_ENABLED=true
