# App
NODE_ENV=production
NEXT_PUBLIC_APP_ENV=production
NEXT_PUBLIC_APP_VERSION=2026.04.18-ops-final
APP_BASE_URL=https://your-domain.com

# Auth
JWT_SECRET=replace_me_with_long_random_secret
BCRYPT_SALT_ROUNDS=12

# Demo access (disabled by default)
DEMO_ACCESS_ENABLED=false
DEMO_ACCESS_ID=replace_with_demo_login_id
DEMO_ACCESS_PASSWORD=replace_with_demo_password
# Existing ACTIVE user id required so the normal session/audit path can be reused
DEMO_ACCESS_USER_ID=replace_with_existing_active_user_id
DEMO_ACCESS_ROLE=LAWYER

# Database
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Cron / internal protection
CRON_SECRET=replace_me_with_long_random_secret

# Feature flags
NEXT_PUBLIC_FF_OPS_QUEUE_BULK_EDIT=true
NEXT_PUBLIC_FF_OPS_QUEUE_REBALANCE_APPLY=true
NEXT_PUBLIC_FF_OPS_QUEUE_WIP_SETTINGS_EDIT=true
NEXT_PUBLIC_FF_OPS_QUEUE_OPTIMISTIC_UI=true

# Observability
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
LOG_LEVEL=info

# Playwright (`npm run test:e2e` — 로컬 기본)
PLAYWRIGHT_BASE_URL=http://localhost:3000
# 스테이징 E2E: 오리진만 바꾼 뒤 `npm run test:e2e:staging` (localhost 기본값은 스크립트에서 거부)
# PLAYWRIGHT_BASE_URL=https://your-staging-host.example.com
